# ==============================================================================
# CONFIGURAÇÕES DE BANCO DE DADOS
# ==============================================================================
# As bases de dados (Primária e Secundária) não possuem um banco/SGBD fixo. 
# Elas podem variar entre PostgreSQL ('pg'), MySQL ('mysql2') ou SQL Server ('mssql').
# Basta preencher as credenciais e o client desejado para cada uma.

# ------------------------------------------------------------------------------
# BANCO DE DADOS PRIMÁRIO
# ------------------------------------------------------------------------------
# Exemplo 1: PostgreSQL
# DB_PRIMARY_CLIENT=pg
# DB_PRIMARY_HOST=localhost
# DB_PRIMARY_PORT=5432
# DB_PRIMARY_USER=postgres
# DB_PRIMARY_PASSWORD=sua_senha
# DB_PRIMARY_NAME=supervisorio_db

# Exemplo 2: MySQL
# DB_PRIMARY_CLIENT=mysql2
# DB_PRIMARY_HOST=localhost
# DB_PRIMARY_PORT=3306
# DB_PRIMARY_USER=root
# DB_PRIMARY_PASSWORD=sua_senha
# DB_PRIMARY_NAME=supervisorio_db

# Exemplo 3: SQL Server (MSSQL)
# DB_PRIMARY_CLIENT=mssql
# DB_PRIMARY_HOST=192.168.0.100
# DB_PRIMARY_PORT=1433
# DB_PRIMARY_USER=sa
# DB_PRIMARY_PASSWORD=sua_senha
# DB_PRIMARY_NAME=supervisorio_db

# (Descomente as variáveis abaixo e preencha com a sua escolha real)
DB_PRIMARY_CLIENT=pg
DB_PRIMARY_HOST=localhost
DB_PRIMARY_PORT=5432
DB_PRIMARY_USER=postgres
DB_PRIMARY_PASSWORD=
DB_PRIMARY_NAME=supervisorio_db


# ------------------------------------------------------------------------------
# BANCO DE DADOS SECUNDÁRIO
# ------------------------------------------------------------------------------
# Exemplo 1: PostgreSQL
# DB_SECONDARY_CLIENT=pg
# DB_SECONDARY_HOST=localhost
# DB_SECONDARY_PORT=5433
# DB_SECONDARY_USER=postgres
# DB_SECONDARY_PASSWORD=sua_senha
# DB_SECONDARY_NAME=supervisorio_db_backup

# Exemplo 2: MySQL
# DB_SECONDARY_CLIENT=mysql2
# DB_SECONDARY_HOST=localhost
# DB_SECONDARY_PORT=3306
# DB_SECONDARY_USER=root
# DB_SECONDARY_PASSWORD=sua_senha
# DB_SECONDARY_NAME=supervisorio_db_backup

# Exemplo 3: SQL Server (MSSQL)
# DB_SECONDARY_CLIENT=mssql
# DB_SECONDARY_HOST=192.168.7.7
# DB_SECONDARY_PORT=1433
# DB_SECONDARY_USER=INTRA
# DB_SECONDARY_PASSWORD=sua_senha
# DB_SECONDARY_NAME=supervisorio_db_backup

# (Descomente as variáveis abaixo e preencha com a sua escolha real)
DB_SECONDARY_CLIENT=mysql2
DB_SECONDARY_HOST=localhost
DB_SECONDARY_PORT=3306
DB_SECONDARY_USER=root
DB_SECONDARY_PASSWORD=
DB_SECONDARY_NAME=supervisorio_db_backup

# ==============================================================================
# E-MAIL / SMTP
# ==============================================================================
SMTP_HOST=smtp.office365.com
SMTP_USER=portal_empresa@empresa.com.br
SMTP_PASS=
SMTP_PORT=587
SMTP_SECURE=false

# ==============================================================================
# FRONTEND / NEXT.JS
# ==============================================================================
# ATENÇÃO: O prefixo "NEXT_PUBLIC_" é OBRIGATÓRIO pelo framework Next.js.
# Variáveis de ambiente sem esse prefixo NUNCA são enviadas ao navegador (ficam 
# exclusivas do backend/Node.js por segurança).
# Como o componente AutoRefresh.tsx roda no navegador do usuário (client-side), 
# ele PRECISA acessar essa variável. Portanto, NÃO troque o nome e NÃO remova 
# o prefixo tentando "padronizar", caso contrário a tela parará de atualizar sozinha!
NEXT_PUBLIC_AUTO_REFRESH_INTERVAL=30000
